    "def introduce(name, age):\n",
    "    print(f\"名前を入力してください: {name}\")\n",
    "    print(f\"現在の年齢を入力してください: {age}\")\n",
    "    print(f\"私の名前は{name}です。来年で{age+1}歳になります。\")\n",
    "\n",
    "introduce(\"SEIU SHU\", 34)"
   ]
  }
